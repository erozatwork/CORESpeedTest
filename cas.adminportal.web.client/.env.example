# ==================================
# VITE ENVIRONMENT VARIABLES
# ==================================
# All environment variables must be prefixed with VITE_ to be exposed to the client
# Copy this file to .env and update the values as needed

# ----------------------------------
# Application URL
# ----------------------------------
# Public URL where the application is hosted
# VITE_PUBLIC_URL='http://localhost:5173'

# ----------------------------------
# API Configuration
# ----------------------------------
# Primary API URL (used by httpClient as baseURL)
# This is the main API endpoint for the application
VITE_API_URL='https://localhost:7002'

# Staging API URL (fallback when MODE !== 'development')
VITE_STAGING_API='https://localhost:7002'

# Development API URL (used when MODE === 'development')
VITE_DEVELOPMENT_API='https://localhost:7002'

# Production/Base API URL
VITE_BASE_URL='https://localhost:7002'

# ----------------------------------
# WebSocket Configuration
# ----------------------------------
# Socket.IO server URL for real-time communication
VITE_SOCKET_URL='http://localhost:9001'

# ----------------------------------
# Authentication Endpoints
# ----------------------------------
# Token verification endpoint
VITE_VERIFY_TOKEN='/api/Authentication/verify_token'

# Login/authentication request endpoint
VITE_LOGIN='/super_application/api/authentication/request'

# User menu list endpoint
VITE_MENU_LIST='/api/Authentication/user_menus'

# User menu paths endpoint
VITE_PATH_LIST='/api/Authentication/user_menu_paths'

# ----------------------------------
# API Security
# ----------------------------------
# API key for authentication/authorization
VITE_API_KEY='api_key'

# ==================================
# PRODUCTION EXAMPLE (Commented)
# ==================================
# Uncomment and update these values for production deployment

# VITE_PUBLIC_URL='https://system.onecoredevit.com/cas/ops_portal/'
# VITE_API_URL='https://system.onecoredevit.com/cas/services/ops_portal/'
# VITE_STAGING_API='https://system.onecoredevit.com/cas/services/ops_portal/'
# VITE_DEVELOPMENT_API='https://system.onecoredevit.com/cas/services/ops_portal/'
# VITE_BASE_URL='https://system.onecoredevit.com/cas/ops_portal/'
# VITE_SOCKET_URL='https://system.onecoredevit.com/cas/site/socket.io'
